SECRET_KEY="django-insecure-replace-me-with-a-long-random-string"
DEBUG=True
# Comma-separated list of allowed hostnames
ALLOWED_HOSTS="localhost,127.0.0.1"
# Set to "production" to enable PostgreSQL and production settings
DJANGO_ENV="development"
SITE_URL="http://localhost:8000"

DB_NAME="your_db_name"
DB_USER="your_db_user"
DB_PASSWORD="your_db_password"
DB_HOST="your_db_host"
DB_PORT=5432

# Used for all uploaded files (product images, artwork, submissions).
# Option A: point to a local service-account JSON file placed at the project root.
#   No extra variables needed — just place firebase-credentials.json there.
# Option B: supply each field individually (preferred for hosted environments).
FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
FIREBASE_TYPE="service_account"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY_ID="your-private-key-id"
# Include the literal newlines — wrap the whole value in double quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR KEY HERE\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_CLIENT_ID="your-client-id"
FIREBASE_AUTH_URI="https://accounts.google.com/o/oauth2/auth"
FIREBASE_TOKEN_URI="https://oauth2.googleapis.com/token"
FIREBASE_AUTH_PROVIDER_CERT_URL="https://www.googleapis.com/oauth2/v1/certs"
FIREBASE_CLIENT_CERT_URL="https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com"
FIREBASE_UNIVERSE_DOMAIN="googleapis.com"

# Use test keys locally (sk_test_... / pk_test_...).
# Switch to live keys (sk_live_... / pk_live_...) in production.
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
# Obtain from Stripe Dashboard → Webhooks, or via `stripe listen` CLI.
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_signing_secret"


# Used for order confirmations, password resets, and email verification.
BREVO_API_KEY="your-brevo-api-key"
# Must match a verified sender in your Brevo account.
DEFAULT_FROM_EMAIL="noreply@yourdomain.com"
DEFAULT_FROM_NAME="Your Store Name"

EMAIL_VERIFICATION_TIMEOUT_HOURS=24
PASSWORD_RESET_TIMEOUT_HOURS=2
